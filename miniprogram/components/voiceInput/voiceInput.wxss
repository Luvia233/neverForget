.voice-input {
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fcb69f 0%, #ff9a9e 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(252, 182, 159, 0.4);
  transition: transform 0.2s ease;
}

.voice-btn:active {
  transform: scale(0.9);
}

.voice-icon {
  font-size: 40rpx;
}

.recording-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 30rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(139, 115, 85, 0.15);
}

.recording-animation {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 60rpx;
}

.wave {
  width: 8rpx;
  height: 20rpx;
  background: linear-gradient(180deg, #fcb69f 0%, #ff9a9e 100%);
  border-radius: 4rpx;
  animation: wave 0.6s ease-in-out infinite;
}

.wave:nth-child(2) {
  animation-delay: 0.1s;
}

.wave:nth-child(3) {
  animation-delay: 0.2s;
}

@keyframes wave {
  0%, 100% {
    height: 20rpx;
  }
  50% {
    height: 50rpx;
  }
}

.recording-text {
  font-size: 28rpx;
  color: #8b7355;
}

.stop-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ff6b6b;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
}

.stop-icon {
  color: white;
  font-size: 32rpx;
}
