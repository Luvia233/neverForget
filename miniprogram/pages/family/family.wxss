.family-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fffaf5 0%, #fff5eb 100%);
  padding-bottom: 40rpx;
}

.family-header {
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #fcb69f 0%, #ff9a9e 100%);
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 30rpx;
}

.family-info {
  text-align: center;
}

.family-name {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 10rpx;
}

.family-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #5d4e37;
}

.member-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(139, 115, 85, 0.1);
}

.member-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-bottom: 1px solid #f5e6d3;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fcb69f 0%, #ff9a9e 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: 700;
  color: white;
}

.member-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #5d4e37;
}

.member-role {
  font-size: 24rpx;
  color: #8b7355;
}

.invite-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(139, 115, 85, 0.1);
}

.invite-code-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.invite-code {
  font-size: 40rpx;
  font-weight: 700;
  color: #5d4e37;
  letter-spacing: 8rpx;
}

.copy-btn {
  background: linear-gradient(135deg, #fcb69f 0%, #ff9a9e 100%);
  color: white;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 20rpx;
  border: none;
}

.invite-info {
  margin-bottom: 24rpx;
}

.invite-hint {
  display: block;
  font-size: 26rpx;
  color: #8b7355;
  margin-bottom: 8rpx;
}

.invite-expire {
  font-size: 24rpx;
  color: #b8a589;
}

.regenerate-btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
}

.info-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(139, 115, 85, 0.1);
}

.info-text {
  font-size: 28rpx;
  color: #8b7355;
  text-align: center;
}

.stats-grid {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  flex: 1;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(139, 115, 85, 0.1);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fcb69f;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8b7355;
}
