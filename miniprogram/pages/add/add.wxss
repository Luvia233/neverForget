.add-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fffaf5 0%, #ffecd2 100%);
  padding: 30rpx;
}

.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #5d4e37;
}

.form-container {
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 36rpx;
}

.label {
  display: block;
  font-size: 30rpx;
  color: #5d4e37;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-row .input {
  flex: 1;
}

.voice-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fcb69f 0%, #ff9a9e 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.voice-icon {
  font-size: 40rpx;
}

.picker-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border: 2px solid #f5e6d3;
  border-radius: 16rpx;
  background: white;
}

.picker-value {
  font-size: 30rpx;
  color: #5d4e37;
}

.picker-placeholder {
  font-size: 30rpx;
  color: #b8a589;
}

.picker-arrow {
  font-size: 24rpx;
  color: #8b7355;
}

.photo-section {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  object-fit: cover;
}

.remove-photo {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ff6b6b;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}

.add-photo {
  width: 200rpx;
  height: 200rpx;
  border: 2px dashed #f5e6d3;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: white;
}

.add-photo-icon {
  font-size: 60rpx;
  color: #fcb69f;
  font-weight: 300;
}

.add-photo-text {
  font-size: 24rpx;
  color: #8b7355;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
}
